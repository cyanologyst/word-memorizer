<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WordReviewReminder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WordReviewReminder"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Word Review Reminder"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="K" Modifiers="Control" Invoked="CommandPaletteAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Word Review"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            CompactPaneLength="48"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            OpenPaneLength="232"
            Background="Transparent"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Dashboard"
                    Tag="home"
                    ToolTipService.ToolTip="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Review" Tag="review" ToolTipService.ToolTip="Review">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE768;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Mistake Lab" Tag="mistakes" ToolTipService.ToolTip="Mistake Lab">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7BA;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Wordlists" Tag="wordlists" ToolTipService.ToolTip="Wordlists">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Statistics" Tag="statistics" ToolTipService.ToolTip="Statistics">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Activity" Tag="calendar" ToolTipService.ToolTip="Activity">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE787;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="AchievementsNavItem" Content="Achievements" Tag="achievements" ToolTipService.ToolTip="Achievements">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7E7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Logs" Tag="logs" ToolTipService.ToolTip="Logs">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE823;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="About" Tag="about" ToolTipService.ToolTip="About">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA3A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="NavFrame" CacheSize="12" />
        </NavigationView>

        <StackPanel
            Grid.RowSpan="2"
            Width="420"
            Margin="0,66,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Canvas.ZIndex="20"
            Spacing="10">
            <InfoBar
                x:Name="GlobalFeedbackBar"
                AutomationProperties.LiveSetting="Polite"
                IsClosable="True"
                IsOpen="False">
                <InfoBar.ActionButton>
                    <Button
                        x:Name="FeedbackActionButton"
                        Visibility="Collapsed"
                        Click="FeedbackActionButton_Click" />
                </InfoBar.ActionButton>
            </InfoBar>

            <Border
                x:Name="UnlockCelebrationHost"
                Width="420"
                MinHeight="132"
                Padding="16"
                Background="{StaticResource PremiumSurfaceStrongBrush}"
                BorderBrush="{StaticResource AchievementUnlockBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Width="92" Height="92" VerticalAlignment="Center">
                    <Ellipse Fill="{StaticResource AchievementBadgeHaloBrush}" />
                    <Image x:Name="UnlockBadgeImage" Width="88" Height="88" Stretch="Uniform" />
                </Grid>
                <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource PremiumWarningBrush}" FontSize="11" FontWeight="SemiBold" Text="ACHIEVEMENT UNLOCKED" />
                    <TextBlock x:Name="UnlockTitleText" FontSize="20" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="UnlockDescriptionText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" MaxLines="2" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <Button
                    Grid.Column="2"
                    Width="32"
                    Height="32"
                    Padding="0"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    AutomationProperties.Name="Dismiss achievement notification"
                    Click="UnlockToastClose_Click"
                    ToolTipService.ToolTip="Dismiss achievement notification">
                    <FontIcon FontSize="13" Glyph="&#xE711;" />
                </Button>
            </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>
