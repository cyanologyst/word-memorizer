<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="WordReviewReminder.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WordReviewReminder">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="PremiumPageBackgroundBrush" Color="#171014" />
            <SolidColorBrush x:Key="PremiumSurfaceBrush" Color="#2A2225" />
            <SolidColorBrush x:Key="PremiumSurfaceStrongBrush" Color="#33282B" />
            <SolidColorBrush x:Key="PremiumLayerBrush" Color="#3A3033" />
            <SolidColorBrush x:Key="PremiumAccentBrush" Color="#FF7A5F" />
            <SolidColorBrush x:Key="PremiumAccentSoftBrush" Color="#33FF7A5F" />
            <SolidColorBrush x:Key="PremiumSuccessBrush" Color="#62D187" />
            <SolidColorBrush x:Key="PremiumSuccessSoftBrush" Color="#2862D187" />
            <SolidColorBrush x:Key="PremiumWarningBrush" Color="#F2C36B" />
            <SolidColorBrush x:Key="PremiumWarningSoftBrush" Color="#28F2C36B" />
            <SolidColorBrush x:Key="PremiumDangerBrush" Color="#FF8B8B" />
            <SolidColorBrush x:Key="PremiumDangerSoftBrush" Color="#28FF8B8B" />

            <Style x:Key="PremiumPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource PremiumSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
            </Style>

            <Style x:Key="PremiumLayerStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource PremiumLayerBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>

            <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="32" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>

            <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{StaticResource PremiumAccentBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource PremiumAccentBrush}" />
                <Setter Property="MinHeight" Value="42" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="SuccessActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{StaticResource PremiumSuccessSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource PremiumSuccessBrush}" />
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="WarningActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{StaticResource PremiumWarningSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource PremiumWarningBrush}" />
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="DangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{StaticResource PremiumDangerSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource PremiumDangerBrush}" />
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
