<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.StatisticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <ScrollViewer>
        <StackPanel Padding="28,20,28,28" Spacing="18">
            <StackPanel>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Statistics" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Momentum, mastery, and words that need attention" />
            </StackPanel>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Daily goal" />
                        <TextBlock x:Name="DailyGoalText" FontSize="30" FontWeight="SemiBold" />
                        <ProgressBar x:Name="DailyGoalBar" Height="7" Maximum="100" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Streak" />
                        <TextBlock x:Name="StreakText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Due now" />
                        <TextBlock x:Name="DueNowText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Total active" />
                        <TextBlock x:Name="TotalActiveText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Mastery levels" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="54" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="New" />
                                <ProgressBar x:Name="NewBar" Grid.Column="1" Height="7" Maximum="100" />
                                <TextBlock x:Name="NewText" Grid.Column="2" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="54" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Learning" />
                                <ProgressBar x:Name="LearningBar" Grid.Column="1" Height="7" Maximum="100" />
                                <TextBlock x:Name="LearningText" Grid.Column="2" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="54" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Familiar" />
                                <ProgressBar x:Name="FamiliarBar" Grid.Column="1" Height="7" Maximum="100" />
                                <TextBlock x:Name="FamiliarText" Grid.Column="2" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="54" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Mastered" />
                                <ProgressBar x:Name="MasteredBar" Grid.Column="1" Height="7" Maximum="100" />
                                <TextBlock x:Name="MasteredText" Grid.Column="2" HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Most missed" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <ItemsRepeater x:Name="MissedRepeater">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5,0,5" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Term}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Misses}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                        <TextBlock x:Name="NoMissesText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="No missed words yet." Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10">
                <StackPanel Spacing="14">
                    <TextBlock Text="Weekly activity" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ItemsRepeater x:Name="ActivityRepeater">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5,0,5" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding DayLabel}" />
                                    <ProgressBar Grid.Column="1" Height="8" Maximum="100" Value="{Binding Progress}" />
                                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Count}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
