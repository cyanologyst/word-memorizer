<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.StatisticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <ScrollViewer Background="{StaticResource PremiumPageBackgroundBrush}">
        <StackPanel Padding="28,20,28,28" Spacing="18">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="18" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Statistics" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Momentum, mastery, and words that need attention" />
                </StackPanel>
                <Border Grid.Column="1" Padding="16" Style="{StaticResource PremiumPanelStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Next best action" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="InsightText" FontSize="18" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="18" Style="{StaticResource PremiumPanelStyle}">
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ProgressRing x:Name="DailyGoalRing" Width="68" Height="68" IsIndeterminate="False" Maximum="100" />
                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="Daily goal" />
                            <TextBlock x:Name="DailyGoalText" Style="{StaticResource MetricValueTextStyle}" />
                            <ProgressBar x:Name="DailyGoalBar" Height="6" Maximum="100" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="Streak" />
                        <TextBlock x:Name="StreakText" Style="{StaticResource MetricValueTextStyle}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" Text="Keep it alive today" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="Due now" />
                        <TextBlock x:Name="DueNowText" Style="{StaticResource MetricValueTextStyle}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" Text="Ready for review" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="Total active" />
                        <TextBlock x:Name="TotalActiveText" Style="{StaticResource MetricValueTextStyle}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" Text="Enabled words" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="20" Style="{StaticResource PremiumPanelStyle}">
                    <StackPanel Spacing="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Mastery distribution" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock x:Name="MasterySummaryText" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="54" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="New" />
                                <ProgressBar x:Name="NewBar" Grid.Column="1" Height="9" Maximum="100" />
                                <TextBlock x:Name="NewText" Grid.Column="2" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="54" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Learning" />
                                <ProgressBar x:Name="LearningBar" Grid.Column="1" Height="9" Maximum="100" />
                                <TextBlock x:Name="LearningText" Grid.Column="2" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="54" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Familiar" />
                                <ProgressBar x:Name="FamiliarBar" Grid.Column="1" Height="9" Maximum="100" />
                                <TextBlock x:Name="FamiliarText" Grid.Column="2" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="54" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Mastered" />
                                <ProgressBar x:Name="MasteredBar" Grid.Column="1" Height="9" Maximum="100" />
                                <TextBlock x:Name="MasteredText" Grid.Column="2" HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" Style="{StaticResource PremiumPanelStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Needs attention" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <ItemsRepeater x:Name="MissedRepeater">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,5,0,5" Padding="12" Background="{StaticResource PremiumLayerBrush}" CornerRadius="10">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Term}" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" Padding="8,3" Background="{StaticResource PremiumWarningSoftBrush}" CornerRadius="10">
                                                <TextBlock FontSize="12" Text="{Binding Misses}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                        <TextBlock x:Name="NoMissesText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="No missed words yet." Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="20" Style="{StaticResource PremiumPanelStyle}">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Weekly heat strip" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Last 7 days" />
                    </Grid>
                    <ItemsRepeater x:Name="ActivityRepeater">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5,0,5" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding DayLabel}" />
                                    <ProgressBar Grid.Column="1" Height="10" Maximum="100" Value="{Binding Progress}" />
                                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Count}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
