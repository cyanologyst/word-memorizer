<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.MistakeLabPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required"
    Loaded="Page_Loaded">
    <Grid Padding="{StaticResource StandardPagePadding}" RowSpacing="14" Background="{StaticResource PremiumPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource PremiumPageTitleStyle}" Text="Mistake Lab" />
                <TextBlock Style="{StaticResource PremiumPageSubtitleStyle}" Text="Words that need more deliberate practice" />
            </StackPanel>
            <Button HorizontalAlignment="Right" Style="{StaticResource PrimaryActionButtonStyle}" AutomationProperties.Name="Practice difficult words" Click="StartPracticeButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE768;" />
                    <TextBlock Text="Practice difficult words" />
                </StackPanel>
            </Button>
        </Grid>
        <Border Grid.Row="1" Padding="16" Style="{StaticResource PremiumPanelStyle}">
            <Grid ColumnSpacing="14" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Spacing="3">
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Queue" />
                    <TextBlock x:Name="QueueCountText" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="3">
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="High urgency" />
                    <TextBlock x:Name="HighUrgencyText" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource PremiumDangerBrush}" />
                </StackPanel>
                <AutoSuggestBox x:Name="SearchBox" Grid.Row="1" Grid.ColumnSpan="2" PlaceholderText="Search difficult words or meanings" QueryIcon="Find" TextChanged="SearchBox_TextChanged" />
                <ComboBox x:Name="SortBox" Grid.Row="1" Grid.Column="2" Header="Sort by" SelectionChanged="SortBox_SelectionChanged">
                    <ComboBoxItem Content="Urgency" />
                    <ComboBoxItem Content="Most misses" />
                    <ComboBoxItem Content="Most lapses" />
                    <ComboBoxItem Content="Last reviewed" />
                    <ComboBoxItem Content="Alphabetical" />
                </ComboBox>
                <ComboBox x:Name="UrgencyFilter" Grid.Row="1" Grid.Column="3" Header="Urgency" MinWidth="150" SelectionChanged="UrgencyFilter_SelectionChanged">
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="High" />
                    <ComboBoxItem Content="Medium" />
                    <ComboBoxItem Content="Low" />
                </ComboBox>
            </Grid>
        </Border>
        <Border Grid.Row="2" Style="{StaticResource PremiumPanelStyle}">
            <Grid>
            <ListView x:Name="MistakesView" Padding="8" HorizontalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Visible" DoubleTapped="MistakesView_DoubleTapped">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="MinHeight" Value="78" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="14" AutomationProperties.Name="{Binding Term}" AutomationProperties.HelpText="{Binding Meaning}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="{Binding Term}" />
                                <TextBlock FontSize="12" Foreground="{StaticResource PremiumWarningBrush}" Text="{Binding Reason}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Meaning}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Meaning}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" Text="MISSES" />
                                <TextBlock Text="{Binding Misses}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" Text="LAPSES" />
                                <TextBlock Text="{Binding Lapses}" />
                            </StackPanel>
                            <Border Grid.Column="3" Padding="8,4" Background="{StaticResource PremiumWarningSoftBrush}" CornerRadius="6" VerticalAlignment="Center">
                                <TextBlock HorizontalAlignment="Center" Text="{Binding Urgency}" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
                <Border x:Name="EmptyMistakesPanel" Margin="16" Style="{StaticResource EmptyStatePanelStyle}" Visibility="Collapsed">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE73E;" FontSize="24" Foreground="{StaticResource PremiumSuccessBrush}" />
                        <TextBlock x:Name="EmptyMistakesTitle" Style="{StaticResource EmptyStateTitleStyle}" Text="No difficult words here" />
                        <TextBlock x:Name="EmptyMistakesMessage" MaxWidth="420" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Words appear after they are skipped or marked for later review." TextAlignment="Center" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
