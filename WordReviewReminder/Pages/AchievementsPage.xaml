<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.AchievementsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged">

    <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="WindowWidthStates">
            <VisualState x:Name="CompactWidth">
                <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="0" />
                </VisualState.StateTriggers>
                <VisualState.Setters>
                    <Setter Target="HeaderSummaryPanel.Visibility" Value="Collapsed" />
                    <Setter Target="CollectionPanel.Visibility" Value="Collapsed" />
                    <Setter Target="CollectionColumn.Width" Value="0" />
                    <Setter Target="HeroBadgeColumn.Width" Value="100" />
                </VisualState.Setters>
            </VisualState>
            <VisualState x:Name="WideWidth">
                <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="1080" />
                </VisualState.StateTriggers>
                <VisualState.Setters>
                    <Setter Target="HeaderSummaryPanel.Visibility" Value="Visible" />
                    <Setter Target="CollectionPanel.Visibility" Value="Visible" />
                    <Setter Target="CollectionColumn.Width" Value="190" />
                    <Setter Target="HeroBadgeColumn.Width" Value="112" />
                </VisualState.Setters>
            </VisualState>
        </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <ScrollViewer Background="{StaticResource PremiumPageBackgroundBrush}">
        <StackPanel Padding="{StaticResource AchievementPagePadding}" Spacing="16">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="10" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <Grid ColumnSpacing="16" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="3">
                    <TextBlock Style="{StaticResource PremiumPageTitleStyle}" Text="Achievement vault" />
                    <TextBlock
                        MaxWidth="680"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Left"
                        Text="A quiet record of your consistency, curiosity, and growing command of every word."
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
                <StackPanel x:Name="HeaderSummaryPanel" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border Padding="10,5" Background="{StaticResource PremiumLayerBrush}" CornerRadius="14">
                        <TextBlock x:Name="UnlockedSummaryText" FontSize="12" FontWeight="SemiBold" Text="0 of 25 unlocked" />
                    </Border>
                    <Border Padding="10,5" Background="{StaticResource PremiumAccentSoftBrush}" CornerRadius="14">
                        <TextBlock x:Name="CompletionSummaryText" FontSize="12" FontWeight="SemiBold" Text="0% complete" />
                    </Border>
                </StackPanel>
            </Grid>

            <Border Padding="18" Style="{StaticResource PremiumPanelStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="HeroBadgeColumn" Width="112" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="CollectionColumn" Width="190" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="100" Height="100" VerticalAlignment="Center">
                        <Ellipse Fill="{StaticResource AchievementBadgeHaloBrush}" />
                        <Ellipse Margin="13" Stroke="{StaticResource AchievementBadgeRingBrush}" StrokeThickness="1" />
                        <Image
                            x:Name="FeaturedBadgeImage"
                            Width="94"
                            Height="94"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Stretch="Uniform" />
                    </Grid>

                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <TextBlock x:Name="FeaturedEyebrowText" Foreground="{StaticResource PremiumWarningBrush}" FontSize="11" FontWeight="SemiBold" Text="CLOSEST MILESTONE" />
                        <TextBlock x:Name="FeaturedTitleText" FontSize="25" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                        <TextBlock
                            x:Name="FeaturedDescriptionText"
                            MaxWidth="620"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="13"
                            HorizontalAlignment="Left"
                            TextWrapping="WrapWholeWords" />
                        <ProgressBar x:Name="FeaturedProgressBar" Height="6" Margin="0,4,0,0" Maximum="100" />
                        <TextBlock x:Name="FeaturedProgressText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    </StackPanel>

                    <Border x:Name="CollectionPanel" Grid.Column="2" Padding="14" Style="{StaticResource PremiumLayerStyle}" VerticalAlignment="Center">
                        <StackPanel Spacing="6">
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Text="Collection progress" />
                            <TextBlock x:Name="CollectionPercentText" FontSize="28" FontWeight="SemiBold" Text="0%" />
                            <ProgressBar x:Name="CollectionProgressBar" Height="6" Maximum="100" />
                            <TextBlock x:Name="CollectionHintText" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid x:Name="AchievementToolbar" ColumnSpacing="14" RowSpacing="8" MinHeight="36" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Spacing="1" VerticalAlignment="Center">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="All achievements" />
                    <TextBlock x:Name="ResultsSummaryText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Text="25 badges" />
                </StackPanel>
                <StackPanel x:Name="AchievementControls" Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <ToggleButton x:Name="AllFilter" Content="All" IsChecked="True" Style="{StaticResource FilterToggleButtonStyle}" Click="FilterButton_Click" Tag="All" />
                    <ToggleButton x:Name="UnlockedFilter" Content="Unlocked" Style="{StaticResource FilterToggleButtonStyle}" Click="FilterButton_Click" Tag="Unlocked" />
                    <ToggleButton x:Name="ProgressFilter" Content="In progress" Style="{StaticResource FilterToggleButtonStyle}" Click="FilterButton_Click" Tag="InProgress" />
                    <ToggleButton x:Name="LockedFilter" Content="Locked" Style="{StaticResource FilterToggleButtonStyle}" Click="FilterButton_Click" Tag="Locked" />
                    <ComboBox x:Name="SortBox" Width="148" SelectedIndex="0" SelectionChanged="SortBox_SelectionChanged" AutomationProperties.Name="Sort achievements">
                        <x:String>Recommended</x:String>
                        <x:String>Closest first</x:String>
                        <x:String>Recently unlocked</x:String>
                        <x:String>Title A-Z</x:String>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <ItemsRepeater x:Name="AchievementRepeater">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        ItemsJustification="Start"
                        ItemsStretch="Fill"
                        MinColumnSpacing="12"
                        MinItemHeight="286"
                        MinItemWidth="244"
                        MinRowSpacing="12" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Height="286"
                            Margin="0"
                            MinWidth="0"
                            Tag="{Binding}"
                            AutomationProperties.Name="{Binding Title}"
                            AutomationProperties.HelpText="{Binding Description}"
                            Style="{StaticResource CardButtonStyle}"
                            Click="AchievementCard_Click"
                            Loaded="BadgeCard_Loaded"
                            PointerEntered="BadgeCard_PointerEntered"
                            PointerExited="BadgeCard_PointerExited"
                            PointerPressed="BadgeCard_PointerPressed"
                            PointerReleased="BadgeCard_PointerReleased"
                            PointerCanceled="BadgeCard_PointerCanceled">
                            <Border
                                Height="286"
                                Padding="14"
                                Background="{Binding CardBackgroundBrush}"
                                BorderBrush="{Binding CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="102" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border HorizontalAlignment="Left" Padding="7,3" Background="{StaticResource PremiumLayerBrush}" CornerRadius="9">
                                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Category}" />
                                        </Border>
                                        <Border Grid.Column="1" Padding="7,3" Background="{Binding StateBackgroundBrush}" CornerRadius="9">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon FontSize="12" Foreground="{Binding StateForegroundBrush}" Glyph="{Binding StateGlyph}" />
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding StateForegroundBrush}" Text="{Binding StatusLabel}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="1">
                                        <Ellipse Width="86" Height="86" Fill="{StaticResource AchievementBadgeBackdropBrush}" />
                                        <Image
                                            Width="98"
                                            Height="98"
                                            Opacity="{Binding BadgeOpacity}"
                                            Source="{Binding IconUri}"
                                            Stretch="Uniform" />
                                    </Grid>

                                    <StackPanel Grid.Row="2" Spacing="4">
                                        <TextBlock FontSize="18" FontWeight="SemiBold" MaxLines="1" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            MinHeight="34"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            FontSize="13"
                                            Text="{Binding Description}"
                                            TextWrapping="WrapWholeWords"
                                            MaxLines="2" />
                                        <TextBlock
                                            Foreground="{StaticResource PremiumWarningBrush}"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="{Binding TierLabel}"
                                            Visibility="{Binding TierVisibility}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Spacing="6">
                                        <ProgressBar Height="5" Foreground="{Binding ProgressBrush}" Maximum="100" Value="{Binding ProgressPercent}" />
                                        <Grid MinHeight="18" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" MaxLines="1" Text="{Binding ProgressLabel}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Foreground="{Binding StateForegroundBrush}" FontSize="12" FontWeight="SemiBold" Text="{Binding ProgressPercentText}" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
            <Border x:Name="EmptyAchievementsPanel" Style="{StaticResource EmptyStatePanelStyle}" Visibility="Collapsed">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE7E7;" FontSize="24" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Style="{StaticResource EmptyStateTitleStyle}" Text="No achievements in this view" />
                    <TextBlock Text="Choose another status filter to see more milestones." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
