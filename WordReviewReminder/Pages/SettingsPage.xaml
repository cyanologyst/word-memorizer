<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged">

    <Grid Background="{StaticResource GlassBaseBrush}">
        <ScrollViewer>
            <StackPanel MaxWidth="1280" Padding="{StaticResource SettingsPagePadding}" Spacing="14" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PremiumPageTitleStyle}" Text="Settings" />
                    <TextBlock Style="{StaticResource PremiumPageSubtitleStyle}" Text="Review, notifications, audio, Windows integration, and local data" />
                </StackPanel>

                <AutoSuggestBox x:Name="SettingsSearchBox" MaxWidth="560" HorizontalAlignment="Left" PlaceholderText="Search settings" QueryIcon="Find" TextChanged="SettingsSearchBox_TextChanged" AutomationProperties.Name="Search settings" />

                <Border x:Name="NoSettingsResults" Style="{StaticResource EmptyStatePanelStyle}" Visibility="Collapsed">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE721;" FontSize="24" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}" Text="No matching settings" />
                        <TextBlock Text="Try reminder, audio, shortcut, backup, or accessibility." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="PreviewColumn" Width="300" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="18">
                        <Border x:Name="ReviewSection" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Review and reminders" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <Grid ColumnSpacing="16" RowSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="130" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Interval" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="How often reminders appear" />
                                    </StackPanel>
                                    <Slider x:Name="IntervalSlider" Grid.Column="1" Minimum="1" Maximum="180" StepFrequency="1" ValueChanged="IntervalSlider_ValueChanged" />
                                    <NumberBox x:Name="IntervalBox" Grid.Column="2" Minimum="1" Maximum="180" SmallChange="1" LargeChange="5" ValueChanged="IntervalBox_ValueChanged" />

                                    <StackPanel Grid.Row="1">
                                        <TextBlock Text="Notification mode" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Popup, toast, or both" />
                                    </StackPanel>
                                    <ComboBox x:Name="NotificationModeBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" MinWidth="260" SelectionChanged="PreviewControl_Changed">
                                        <ComboBoxItem Content="Popup" />
                                        <ComboBoxItem Content="Toast" />
                                        <ComboBoxItem Content="Both" />
                                    </ComboBox>

                                    <StackPanel Grid.Row="2">
                                        <TextBlock Text="Popup duration" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Seconds before a card closes" />
                                    </StackPanel>
                                    <Slider x:Name="PopupDurationSlider" Grid.Row="2" Grid.Column="1" Minimum="5" Maximum="120" StepFrequency="1" ValueChanged="PopupDurationSlider_ValueChanged" />
                                    <NumberBox x:Name="PopupDurationBox" Grid.Row="2" Grid.Column="2" Minimum="5" Maximum="120" SmallChange="1" LargeChange="5" ValueChanged="PopupDurationBox_ValueChanged" />

                                    <StackPanel Grid.Row="3">
                                        <TextBlock Text="Word selection" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Prioritize due words or shuffle" />
                                    </StackPanel>
                                    <ComboBox x:Name="SelectionModeBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" MinWidth="260" SelectionChanged="PreviewControl_Changed">
                                        <ComboBoxItem Content="Due first" />
                                        <ComboBoxItem Content="Random" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="NotificationsSection" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="16">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Quiet hours" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="Pause reminders during a daily time window" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="QuietHoursToggle" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="PreviewControl_Changed" />
                                </Grid>
                                <Grid x:Name="QuietHoursFields" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Start" />
                                        <TimePicker x:Name="QuietStartPicker" ClockIdentifier="24HourClock" SelectedTimeChanged="QuietTimePicker_SelectedTimeChanged" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <TextBlock Text="End" />
                                        <TimePicker x:Name="QuietEndPicker" ClockIdentifier="24HourClock" SelectedTimeChanged="QuietTimePicker_SelectedTimeChanged" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="SystemSection" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Windows and shortcuts" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <Grid ColumnSpacing="18" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Spacing="2"><TextBlock Text="Start with Windows" /><TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="Launch quietly when you sign in" /></StackPanel>
                                    <ToggleSwitch x:Name="StartWithWindowsToggle" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="PreviewControl_Changed" />
                                    <StackPanel Grid.Row="1" Spacing="2"><TextBlock Text="Global review shortcut" /><TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="Open review from anywhere with Ctrl+Alt+R" /></StackPanel>
                                    <ToggleSwitch x:Name="GlobalHotkeyToggle" Grid.Row="1" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="PreviewControl_Changed" />
                                    <StackPanel Grid.Row="2" Spacing="2"><TextBlock Text="Clipboard quick-add prompts" /><TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="Offer to save copied vocabulary" /></StackPanel>
                                    <ToggleSwitch x:Name="ClipboardQuickAddToggle" Grid.Row="2" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="PreviewControl_Changed" />
                                    <StackPanel Grid.Row="3" Spacing="2"><TextBlock Text="Compact fullscreen reminders" /><TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="Use a smaller card over fullscreen apps" /></StackPanel>
                                    <ToggleSwitch x:Name="CompactFullscreenToggle" Grid.Row="3" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="PreviewControl_Changed" />
                                    <StackPanel Grid.Row="4" Spacing="2"><TextBlock Text="Sound cues" /><TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="Play restrained review feedback sounds" /></StackPanel>
                                    <ToggleSwitch x:Name="SoundToggle" Grid.Row="4" Grid.Column="1" OffContent="Silent" OnContent="On" Toggled="PreviewControl_Changed" />
                                    <StackPanel Grid.Row="5" Spacing="2"><TextBlock Text="Default session size" /><TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="Words in a new review session" /></StackPanel>
                                    <NumberBox x:Name="DefaultSessionSizeBox" Grid.Row="5" Grid.Column="1" Width="130" Minimum="5" Maximum="100" SmallChange="5" SpinButtonPlacementMode="Inline" ValueChanged="DefaultSessionSizeBox_ValueChanged" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="AudioSection" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Pronunciation" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <ComboBox x:Name="VoiceBox" Header="Windows voice" SelectionChanged="PreviewControl_Changed" />
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SpeechRateSlider" Header="Speaking rate" Minimum="0.5" Maximum="2" StepFrequency="0.1" ValueChanged="SpeechRateSlider_ValueChanged" />
                                    <Button Grid.Column="1" VerticalAlignment="Bottom" AutomationProperties.Name="Test pronunciation voice" Click="TestVoiceButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE767;" />
                                            <TextBlock Text="Test" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="WordDetailsSection" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Word details and accessibility" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Online dictionary enrichment" />
                                        <TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="Look up definitions and examples when local details are incomplete" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="DictionaryLookupToggle" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="PreviewControl_Changed" />
                                </Grid>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE7F8;" Foreground="{StaticResource PremiumAccentBrush}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Windows accessibility preferences" />
                                        <TextBlock x:Name="AccessibilityStatusText" Style="{StaticResource PremiumCaptionTextStyle}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="DataSection" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Data and backup" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Create one portable archive containing wordlists, progress, settings, achievements, enrichment cache, and logs." TextWrapping="WrapWholeWords" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button AutomationProperties.Name="Create a local data backup" Click="BackupButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE74E;" />
                                            <TextBlock Text="Create backup" />
                                        </StackPanel>
                                    </Button>
                                    <Button AutomationProperties.Name="Restore a local data backup" Click="RestoreButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE777;" />
                                            <TextBlock Text="Restore backup" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <Rectangle Height="1" Fill="{StaticResource PremiumGlassBorderSubtleBrush}" />
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Reset preferences" />
                                        <TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="Restore reminder, review, audio, and Windows integration defaults" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Foreground="{StaticResource PremiumDangerBrush}" AutomationProperties.Name="Reset all settings to defaults" Click="ResetDefaultsButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE777;" />
                                            <TextBlock Text="Reset defaults" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border x:Name="PreviewPane" Grid.Column="1" Padding="18" Style="{StaticResource PremiumRaisedPanelStyle}" VerticalAlignment="Top">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Live preview" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <StackPanel Spacing="10" Margin="0,4,0,2">
                                <TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="REVIEW NOW" />
                                <TextBlock Text="Refuge" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock Text="shelter, asylum, haven" TextWrapping="WrapWholeWords" />
                                <ProgressBar x:Name="PreviewDurationBar" Height="6" Maximum="120" />
                            </StackPanel>
                            <Rectangle Height="1" Fill="{StaticResource PremiumGlassBorderSubtleBrush}" />
                            <TextBlock x:Name="PreviewSummaryText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="15 min" AutomationProperties.Name="Set reminder interval to 15 minutes" Click="Preset15Button_Click" />
                                <Button Content="30 min" AutomationProperties.Name="Set reminder interval to 30 minutes" Click="Preset30Button_Click" />
                                <Button Content="60 min" AutomationProperties.Name="Set reminder interval to 60 minutes" Click="Preset60Button_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="SaveBar" VerticalAlignment="Bottom" Padding="24,12" Background="{StaticResource GlassRaisedBrush}" BorderBrush="{StaticResource PremiumGlassBorderBrush}" BorderThickness="0,1,0,0" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Button Style="{StaticResource PrimaryActionButtonStyle}" Content="Save settings" AutomationProperties.Name="Save settings" Click="SaveButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
