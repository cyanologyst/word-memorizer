<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged">

    <Grid Background="{StaticResource PremiumPageBackgroundBrush}">
        <ScrollViewer>
            <StackPanel Padding="24,18,24,80" Spacing="14">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Reminder timing, quiet hours, and notification behavior" />
                </StackPanel>

                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="PreviewColumn" Width="300" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="18">
                        <Border Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Reminder behavior" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <Grid ColumnSpacing="16" RowSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="130" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Interval" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="How often reminders appear" />
                                    </StackPanel>
                                    <Slider x:Name="IntervalSlider" Grid.Column="1" Minimum="1" Maximum="180" StepFrequency="1" ValueChanged="IntervalSlider_ValueChanged" />
                                    <NumberBox x:Name="IntervalBox" Grid.Column="2" Minimum="1" Maximum="180" SmallChange="1" LargeChange="5" ValueChanged="IntervalBox_ValueChanged" />

                                    <StackPanel Grid.Row="1">
                                        <TextBlock Text="Notification mode" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Popup, toast, or both" />
                                    </StackPanel>
                                    <ComboBox x:Name="NotificationModeBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" MinWidth="260" SelectionChanged="PreviewControl_Changed">
                                        <ComboBoxItem Content="Popup" />
                                        <ComboBoxItem Content="Toast" />
                                        <ComboBoxItem Content="Both" />
                                    </ComboBox>

                                    <StackPanel Grid.Row="2">
                                        <TextBlock Text="Popup duration" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Seconds before a card closes" />
                                    </StackPanel>
                                    <Slider x:Name="PopupDurationSlider" Grid.Row="2" Grid.Column="1" Minimum="5" Maximum="120" StepFrequency="1" ValueChanged="PopupDurationSlider_ValueChanged" />
                                    <NumberBox x:Name="PopupDurationBox" Grid.Row="2" Grid.Column="2" Minimum="5" Maximum="120" SmallChange="1" LargeChange="5" ValueChanged="PopupDurationBox_ValueChanged" />

                                    <StackPanel Grid.Row="3">
                                        <TextBlock Text="Word selection" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Prioritize due words or shuffle" />
                                    </StackPanel>
                                    <ComboBox x:Name="SelectionModeBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" MinWidth="260" SelectionChanged="PreviewControl_Changed">
                                        <ComboBoxItem Content="Due first" />
                                        <ComboBoxItem Content="Random" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Quiet hours" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <ToggleSwitch x:Name="QuietHoursToggle" Header="Pause reminders during quiet hours" Toggled="PreviewControl_Changed" />
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Start" />
                                        <TimePicker x:Name="QuietStartPicker" ClockIdentifier="24HourClock" SelectedTimeChanged="QuietTimePicker_SelectedTimeChanged" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <TextBlock Text="End" />
                                        <TimePicker x:Name="QuietEndPicker" ClockIdentifier="24HourClock" SelectedTimeChanged="QuietTimePicker_SelectedTimeChanged" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="System" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <ToggleSwitch x:Name="StartWithWindowsToggle" Header="Start with Windows" Toggled="PreviewControl_Changed" />
                                <ToggleSwitch x:Name="GlobalHotkeyToggle" Header="Global review shortcut" OffContent="Off" OnContent="Ctrl+Alt+R" Toggled="PreviewControl_Changed" />
                                <ToggleSwitch x:Name="ClipboardQuickAddToggle" Header="Clipboard quick-add prompts" OffContent="Off" OnContent="On" Toggled="PreviewControl_Changed" />
                                <ToggleSwitch x:Name="CompactFullscreenToggle" Header="Compact reminders during fullscreen activity" Toggled="PreviewControl_Changed" />
                                <ToggleSwitch x:Name="SoundToggle" Header="Sound cues" OffContent="Silent" OnContent="On" Toggled="PreviewControl_Changed" />
                                <NumberBox x:Name="DefaultSessionSizeBox" Header="Default session size" Minimum="5" Maximum="100" SmallChange="5" ValueChanged="DefaultSessionSizeBox_ValueChanged" />
                            </StackPanel>
                        </Border>

                        <Border Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Pronunciation" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <ComboBox x:Name="VoiceBox" Header="Windows voice" SelectionChanged="PreviewControl_Changed" />
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SpeechRateSlider" Header="Speaking rate" Minimum="0.5" Maximum="2" StepFrequency="0.1" ValueChanged="SpeechRateSlider_ValueChanged" />
                                    <Button Grid.Column="1" VerticalAlignment="Bottom" AutomationProperties.Name="Test pronunciation voice" Click="TestVoiceButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE767;" />
                                            <TextBlock Text="Test" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="18" Style="{StaticResource PremiumPanelStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Backup and restore" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Create one portable archive containing wordlists, progress, settings, achievements, enrichment cache, and logs." TextWrapping="WrapWholeWords" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Click="BackupButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE74E;" />
                                            <TextBlock Text="Create backup" />
                                        </StackPanel>
                                    </Button>
                                    <Button Click="RestoreButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE777;" />
                                            <TextBlock Text="Restore backup" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border x:Name="PreviewPane" Grid.Column="1" Padding="18" Style="{StaticResource PremiumPanelStyle}" VerticalAlignment="Top">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Live preview" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <Border Padding="16" Background="{StaticResource PremiumSurfaceStrongBrush}" CornerRadius="8">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Review now" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="Refuge" FontSize="30" FontWeight="SemiBold" />
                                    <TextBlock Text="shelter, asylum, haven" TextWrapping="WrapWholeWords" />
                                    <ProgressBar x:Name="PreviewDurationBar" Height="6" Maximum="120" />
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="PreviewSummaryText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="15 min" Click="Preset15Button_Click" />
                                <Button Content="30 min" Click="Preset30Button_Click" />
                                <Button Content="60 min" Click="Preset60Button_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="SaveBar" VerticalAlignment="Bottom" Padding="24,12" Background="{StaticResource PremiumSurfaceBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Button Style="{StaticResource PrimaryActionButtonStyle}" Content="Save settings" Click="SaveButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
