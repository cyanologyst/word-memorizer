<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged">

    <ScrollViewer Background="{StaticResource GlassBaseBrush}" HorizontalScrollBarVisibility="Disabled">
        <Grid MaxWidth="1280" Padding="24,18,24,24" HorizontalAlignment="Stretch">
            <StackPanel Spacing="14">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="12" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <Grid x:Name="HeaderGrid" Margin="0,4,0,4" ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource PremiumPageTitleStyle}" Text="Dashboard" />
                            <TextBlock Style="{StaticResource PremiumBodyTextStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Today&apos;s command center for keeping words warm in memory" />
                            <StackPanel x:Name="HeaderChips" Orientation="Horizontal" Spacing="10">
                                <Border Padding="10,5" Background="{StaticResource PremiumAccentSoftBrush}" CornerRadius="14">
                                    <TextBlock x:Name="NextReminderChipText" FontSize="12" Text="Next in 5 min" />
                                </Border>
                                <Border Padding="10,5" Background="{StaticResource PremiumSuccessSoftBrush}" CornerRadius="14">
                                    <TextBlock x:Name="DailyGoalChipText" FontSize="12" Text="Daily goal active" />
                                </Border>
                                <Border Padding="10,5" Background="{StaticResource PremiumLayerBrush}" CornerRadius="14">
                                    <TextBlock x:Name="ModeChipText" FontSize="12" Text="Popup + toast" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="HeaderActions" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Style="{StaticResource PrimaryActionButtonStyle}" MinWidth="180" Click="ReviewNowButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="9">
                                    <FontIcon Glyph="&#xE768;" />
                                    <TextBlock Text="Review now" />
                                </StackPanel>
                            </Button>
                            <Button Width="40" Height="40" Padding="0" AutomationProperties.Name="More dashboard actions" ToolTipService.ToolTip="More dashboard actions">
                                <FontIcon Glyph="&#xE712;" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Open mini widget" Click="MiniButton_Click" />
                                        <MenuFlyoutItem Text="Pause reminders for 30 minutes" Click="PauseQuickButton_Click" />
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="Refresh dashboard" Click="RefreshButton_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                </Grid>

                <Grid x:Name="MetricGrid" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="MetricColumn1" Width="*" />
                        <ColumnDefinition x:Name="MetricColumn2" Width="*" />
                        <ColumnDefinition x:Name="MetricColumn3" Width="*" />
                        <ColumnDefinition x:Name="MetricColumn4" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="16" Style="{StaticResource PremiumPanelStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="Active words" />
                            <TextBlock x:Name="ActiveWordsText" Style="{StaticResource MetricValueTextStyle}" />
                            <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" Text="Enabled across lists" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="16" Style="{StaticResource PremiumPanelStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="Today" />
                            <TextBlock x:Name="ReviewedTodayText" Style="{StaticResource MetricValueTextStyle}" />
                            <ProgressBar x:Name="DailyGoalBar" Height="7" Maximum="100" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="StreakCard" Grid.Column="2" Padding="16" Style="{StaticResource PremiumPanelStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="Streak" />
                            <TextBlock x:Name="StreakText" Style="{StaticResource MetricValueTextStyle}" />
                            <TextBlock x:Name="StreakHintText" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="DueCard" Grid.Column="3" Padding="16" Style="{StaticResource PremiumPanelStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="Due now" />
                            <TextBlock x:Name="DueNowText" Style="{StaticResource MetricValueTextStyle}" />
                            <TextBlock x:Name="NextReminderText" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" TextWrapping="NoWrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="BottomGrid" ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition x:Name="BottomColumn2" Width="0.85*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Padding="18" Style="{StaticResource PremiumRaisedPanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Weekly heat strip" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <ItemsRepeater x:Name="ActivityRepeater">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4,0,4" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="34" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding DayLabel}" />
                                            <ProgressBar Grid.Column="1" Height="8" Maximum="100" Value="{Binding Progress}" />
                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="12" Text="{Binding Count}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>

                    <Border x:Name="WordlistsPanel" Grid.Column="1" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Enabled wordlists" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <ItemsRepeater x:Name="EnabledListsRepeater">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4,0,4" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="6" Height="36" Background="{StaticResource PremiumAccentBrush}" CornerRadius="3" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Source}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Page>
