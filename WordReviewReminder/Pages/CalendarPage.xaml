<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.CalendarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">
    <ScrollViewer Background="{StaticResource PremiumPageBackgroundBrush}">
        <StackPanel Padding="24,18,24,24" Spacing="14">
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Activity" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Thirteen weeks of review consistency" />
            </StackPanel>
            <Border Padding="18" Style="{StaticResource PremiumPanelStyle}">
                <StackPanel Spacing="14">
                    <Grid>
                        <TextBlock Style="{StaticResource PageSectionTitleStyle}" Text="Review calendar" />
                        <TextBlock x:Name="SummaryText" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                    <ItemsRepeater x:Name="CalendarRepeater">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MaximumRowsOrColumns="13" MinColumnSpacing="8" MinRowSpacing="8" ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Button MinWidth="58" Height="48" Padding="6" Background="{Binding Background}" BorderBrush="Transparent" CornerRadius="5" ToolTipService.ToolTip="{Binding Tooltip}" Tag="{Binding}" Click="CalendarDay_Click">
                                    <StackPanel>
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding Day}" />
                                        <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Count}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Less" />
                        <Border Width="18" Height="18" Background="{StaticResource PremiumLayerBrush}" CornerRadius="3" />
                        <Border Width="18" Height="18" Background="#594D5F" CornerRadius="3" />
                        <Border Width="18" Height="18" Background="#8F665E" CornerRadius="3" />
                        <Border Width="18" Height="18" Background="{StaticResource PremiumAccentBrush}" CornerRadius="3" />
                        <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="More" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
