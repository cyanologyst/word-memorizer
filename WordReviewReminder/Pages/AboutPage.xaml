<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged">

    <ScrollViewer Background="{StaticResource PremiumPageBackgroundBrush}">
        <StackPanel Padding="{StaticResource StandardPagePadding}" Spacing="14">
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource PremiumPageTitleStyle}" Text="About" />
                <TextBlock Style="{StaticResource PremiumPageSubtitleStyle}" Text="Product information, documentation, and local storage" />
            </StackPanel>

            <Border Padding="24" Style="{StaticResource PremiumPanelStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="72" Height="72" Background="{StaticResource PremiumAccentSoftBrush}" CornerRadius="8">
                        <Image Width="64" Height="64" Source="ms-appx:///Assets/AppLogo.png" Stretch="Uniform" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="Word Review Reminder" FontSize="26" FontWeight="SemiBold" />
                        <TextBlock Text="A focused Windows 11 vocabulary companion" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="VersionText" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="InfoGrid" ColumnSpacing="14" RowSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="InfoColumn2" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Padding="20" Style="{StaticResource PremiumPanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource PageSectionTitleStyle}" Text="Wordlists and documentation" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="The app includes the TOEFL 550 seed list and supports additional validated .wordlist.json databases." />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button AutomationProperties.Name="Open wordlist format documentation" Click="DocumentationButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A5;" />
                                    <TextBlock Text="Format guide" />
                                </StackPanel>
                            </Button>
                            <Button AutomationProperties.Name="Open project on GitHub" Click="GitHubButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE943;" />
                                    <TextBlock Text="GitHub" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border x:Name="LocalDataCard" Grid.Column="1" Padding="20" Style="{StaticResource PremiumPanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource PageSectionTitleStyle}" Text="Local data" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Settings, progress, wordlists, achievements, and review history remain on this PC." TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="StoragePathText" FontFamily="Cascadia Mono" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="WrapWholeWords" />
                        <Button HorizontalAlignment="Left" AutomationProperties.Name="Open local data folder" Click="OpenStorageButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;" />
                                <TextBlock Text="Open folder" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="SupportGrid" ColumnSpacing="14" RowSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="SupportColumn2" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Padding="20" Style="{StaticResource PremiumPanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource PageSectionTitleStyle}" Text="Privacy" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="No account or cloud sync is required. Wordlists, settings, progress, achievements, and review history stay in your local data folder." />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="When online dictionary enrichment is enabled, only the word being looked up is sent to the configured public dictionary service." />
                    </StackPanel>
                </Border>
                <Border x:Name="DiagnosticsCard" Grid.Column="1" Padding="20" Style="{StaticResource PremiumPanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource PageSectionTitleStyle}" Text="Support and diagnostics" />
                        <TextBlock x:Name="DiagnosticsSummaryText" Style="{StaticResource PremiumCaptionTextStyle}" TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button AutomationProperties.Name="Copy application diagnostics" Click="CopyDiagnosticsButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8C8;" />
                                    <TextBlock Text="Copy diagnostics" />
                                </StackPanel>
                            </Button>
                            <Button AutomationProperties.Name="Open support issues on GitHub" Click="SupportButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE897;" />
                                    <TextBlock Text="Support" />
                                </StackPanel>
                            </Button>
                            <Button AutomationProperties.Name="Open third-party license notices" Click="LicensesButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A5;" />
                                    <TextBlock Text="Licenses" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="20" Style="{StaticResource PremiumPanelStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="7">
                        <TextBlock Style="{StaticResource PageSectionTitleStyle}" Text="Updates" />
                        <TextBlock x:Name="UpdateStatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Windows checks for signed updates automatically." TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ProgressRing x:Name="UpdateProgressRing" Width="18" Height="18" IsActive="False" Visibility="Collapsed" />
                        <Button x:Name="InstallUpdateButton" Visibility="Collapsed" AutomationProperties.Name="Open Windows App Installer to update" Click="InstallUpdateButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE896;" />
                                <TextBlock Text="Install update" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CheckUpdateButton" AutomationProperties.Name="Check for application updates" Click="CheckUpdateButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE895;" />
                                <TextBlock Text="Check now" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
