<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.WordlistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged">

    <Grid Padding="{StaticResource StandardPagePadding}" RowSpacing="14" Background="{StaticResource PremiumPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="HeaderGrid" ColumnSpacing="16" RowSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="HeaderActionColumn" Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource PremiumPageTitleStyle}" Text="Wordlists" />
                <TextBlock Style="{StaticResource PremiumPageSubtitleStyle}" Text="Import, enable, and maintain local JSON vocabulary databases" />
            </StackPanel>
            <CommandBar x:Name="PageCommandBar" Grid.Column="1" Background="Transparent" DefaultLabelPosition="Right" IsDynamicOverflowEnabled="True">
                <AppBarButton x:Name="ImportButton" Icon="Import" Label="Import" Click="ImportButton_Click" />
                <AppBarButton Icon="Add" Label="Add word" Click="AddWordButton_Click" />
                <AppBarButton x:Name="ExportListButton" Icon="Save" Label="Export list" Click="ExportListButton_Click" />
                <AppBarButton x:Name="DeleteListButton" Icon="Delete" Label="Delete list" Foreground="{StaticResource PremiumDangerBrush}" Click="DeleteListButton_Click" />
                <AppBarButton Icon="Refresh" Label="Refresh" Click="RefreshButton_Click" />
            </CommandBar>
        </Grid>

        <Grid x:Name="ContentGrid" Grid.Row="1" ColumnSpacing="14" RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ListsColumn" Width="240" />
                <ColumnDefinition x:Name="WordsColumn" Width="*" />
                <ColumnDefinition x:Name="PreviewColumn" Width="280" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ListsRow" Height="*" />
                <RowDefinition x:Name="WordsRow" Height="0" />
            </Grid.RowDefinitions>

            <ListView x:Name="WordListView" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="WordListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,2" Padding="10" Background="Transparent" CornerRadius="6">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="4" Height="52" Background="{StaticResource PremiumAccentBrush}" CornerRadius="2" />
                                <StackPanel Grid.Column="1" Spacing="5">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Source}" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Padding="7,3" Background="{StaticResource PremiumLayerBrush}" CornerRadius="6">
                                            <TextBlock FontSize="11" Text="{Binding WordCountLabel}" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding ReviewProgressLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border x:Name="WordsPane" Grid.Column="1" Padding="16" Style="{StaticResource PremiumPanelStyle}">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="7">
                            <TextBlock x:Name="SelectedListTitle" Style="{StaticResource SubtitleTextBlockStyle}" MaxLines="2" TextWrapping="WrapWholeWords" />
                            <TextBlock x:Name="SelectedListMeta" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxLines="2" TextTrimming="CharacterEllipsis" TextWrapping="WrapWholeWords" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Padding="8,4" Background="{StaticResource PremiumSuccessSoftBrush}" CornerRadius="6">
                                    <TextBlock x:Name="SchemaStatusText" FontSize="12" Text="Schema v1" />
                                </Border>
                                <Border Padding="8,4" Background="{StaticResource PremiumAccentSoftBrush}" CornerRadius="6">
                                    <TextBlock x:Name="ReviewProgressText" FontSize="12" Text="Not reviewed" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <ToggleSwitch x:Name="EnableSelectedToggle" Grid.Column="1" Header="Enabled" Toggled="EnableSelectedToggle_Toggled" />
                    </Grid>
                    <Grid x:Name="WordToolbarGrid" Grid.Row="1" ColumnSpacing="10" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="SortColumn" Width="170" />
                            <ColumnDefinition x:Name="FilterColumn" Width="150" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition x:Name="CompactToolbarRow" Height="0" />
                        </Grid.RowDefinitions>
                        <AutoSuggestBox x:Name="SearchBox" Header="Search" PlaceholderText="Word, meaning, pronunciation, or type" TextChanged="SearchBox_TextChanged" QueryIcon="Find" AutomationProperties.Name="Search words" />
                        <ComboBox x:Name="SortBox" Grid.Column="1" Header="Sort" SelectedIndex="0" SelectionChanged="SortBox_SelectionChanged" AutomationProperties.Name="Sort words">
                            <x:String>List order</x:String>
                            <x:String>Alphabetical</x:String>
                            <x:String>Part of speech</x:String>
                            <x:String>Recently reviewed</x:String>
                        </ComboBox>
                        <ComboBox x:Name="PartOfSpeechFilter" Grid.Column="2" Header="Filter" SelectedIndex="0" SelectionChanged="PartOfSpeechFilter_SelectionChanged" AutomationProperties.Name="Filter by part of speech" />
                    </Grid>
                    <Grid Grid.Row="2" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ResultCountText" AutomationProperties.LiveSetting="Polite" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button x:Name="EditSelectedButton" Style="{StaticResource CompactIconButtonStyle}" AutomationProperties.Name="Edit selected word" ToolTipService.ToolTip="Edit selected word" Click="EditWordButton_Click">
                                <FontIcon Glyph="&#xE70F;" FontSize="16" />
                            </Button>
                            <Button x:Name="OpenSelectedButton" Style="{StaticResource CompactIconButtonStyle}" AutomationProperties.Name="Open selected word details" ToolTipService.ToolTip="Open details" Click="OpenWordDetailsButton_Click">
                                <FontIcon Glyph="&#xE946;" FontSize="16" />
                            </Button>
                            <Button x:Name="DeleteSelectedButton" Style="{StaticResource CompactIconButtonStyle}" Foreground="{StaticResource PremiumDangerBrush}" AutomationProperties.Name="Delete selected words" ToolTipService.ToolTip="Delete selected" Click="DeleteWordButton_Click">
                                <FontIcon Glyph="&#xE74D;" FontSize="16" />
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="3">
                    <ListView x:Name="WordsView" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="Extended" IsMultiSelectCheckBoxEnabled="True" SelectionChanged="WordsView_SelectionChanged">
                        <ListView.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Open details" Icon="OpenFile" Click="OpenWordDetailsButton_Click" />
                                <MenuFlyoutItem Text="Edit" Icon="Edit" Click="EditWordButton_Click" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Delete" Icon="Delete" Foreground="{StaticResource PremiumDangerBrush}" Click="DeleteWordButton_Click" />
                            </MenuFlyout>
                        </ListView.ContextFlyout>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" Padding="10" Background="{StaticResource PremiumLayerBrush}" CornerRadius="6">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Term}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding Pronunciation}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Padding="8,4" Background="{StaticResource PremiumAccentSoftBrush}" CornerRadius="6" VerticalAlignment="Top">
                                                <TextBlock FontSize="12" Text="{Binding PartOfSpeech}" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ShortMeaning}" TextWrapping="WrapWholeWords" MaxLines="2" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                        <Border x:Name="EmptyWordsPanel" Margin="8" Style="{StaticResource EmptyStatePanelStyle}" Visibility="Collapsed">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE8D2;" FontSize="24" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="EmptyWordsTitle" Style="{StaticResource EmptyStateTitleStyle}" Text="No words in this list" />
                                <TextBlock x:Name="EmptyWordsMessage" MaxWidth="360" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Add a word or import a populated wordlist." TextAlignment="Center" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="PreviewPane" Grid.Column="2" Padding="16" Style="{StaticResource PremiumPanelStyle}">
                <StackPanel Spacing="13">
                    <TextBlock Text="Word preview" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="PreviewTermText" FontSize="32" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="PreviewMetaText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="PreviewMeaningText" TextWrapping="WrapWholeWords" />
                    <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Padding="8,4" Background="{StaticResource PremiumLayerBrush}" CornerRadius="6">
                            <TextBlock x:Name="PreviewChapterText" FontSize="12" />
                        </Border>
                        <Border Padding="8,4" Background="{StaticResource PremiumAccentSoftBrush}" CornerRadius="6">
                            <TextBlock x:Name="PreviewTagsText" FontSize="12" />
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="PreviewReviewText" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" Text="Select a row to inspect it before editing or deleting." TextWrapping="WrapWholeWords" />
                    <Button HorizontalAlignment="Stretch" AutomationProperties.Name="Open selected word details" Click="OpenWordDetailsButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE946;" />
                            <TextBlock Text="Open rich details" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border x:Name="NoWordlistsPanel" Grid.RowSpan="2" Grid.ColumnSpan="3" Margin="0" Style="{StaticResource EmptyStatePanelStyle}" Visibility="Collapsed">
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE8D2;" FontSize="28" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Style="{StaticResource EmptyStateTitleStyle}" Text="Your vocabulary library is empty" />
                    <TextBlock MaxWidth="440" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Import a .wordlist.json file or add your first personal word." TextAlignment="Center" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ProgressRing x:Name="OperationProgress" Width="16" Height="16" IsActive="False" Visibility="Collapsed" />
            <TextBlock x:Name="StatusText" Grid.Column="1" AutomationProperties.LiveSetting="Polite" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
    </Grid>
</Page>
