<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.WordlistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged">

    <Grid Padding="24,18,24,24" RowSpacing="14" Background="{StaticResource PremiumPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Wordlists" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Import, enable, and maintain local JSON vocabulary databases" />
            </StackPanel>
            <CommandBar Grid.Column="1" Background="Transparent" DefaultLabelPosition="Right" IsDynamicOverflowEnabled="True">
                <AppBarButton Icon="Import" Label="Import" Click="ImportButton_Click" />
                <AppBarButton Icon="Add" Label="Add word" Click="AddWordButton_Click" />
                <AppBarButton Icon="Edit" Label="Edit" Click="EditWordButton_Click" />
                <AppBarButton Icon="Delete" Label="Delete" Click="DeleteWordButton_Click" />
                <AppBarButton Icon="Refresh" Label="Refresh" Click="RefreshButton_Click" />
            </CommandBar>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ListsColumn" Width="240" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="PreviewColumn" Width="280" />
            </Grid.ColumnDefinitions>

            <ListView x:Name="WordListView" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="WordListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,2" Padding="10" Background="Transparent" CornerRadius="6">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="4" Height="52" Background="{StaticResource PremiumAccentBrush}" CornerRadius="2" />
                                <StackPanel Grid.Column="1" Spacing="5">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Source}" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Padding="7,3" Background="{StaticResource PremiumLayerBrush}" CornerRadius="6">
                                            <TextBlock FontSize="11" Text="{Binding Id}" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Grid.Column="1" Padding="16" Style="{StaticResource PremiumPanelStyle}">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="7">
                            <TextBlock x:Name="SelectedListTitle" Style="{StaticResource SubtitleTextBlockStyle}" MaxLines="2" TextWrapping="WrapWholeWords" />
                            <TextBlock x:Name="SelectedListMeta" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Padding="8,4" Background="{StaticResource PremiumSuccessSoftBrush}" CornerRadius="6">
                                    <TextBlock FontSize="12" Text="Schema checked" />
                                </Border>
                                <Border Padding="8,4" Background="{StaticResource PremiumWarningSoftBrush}" CornerRadius="6">
                                    <TextBlock FontSize="12" Text="No dupes" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <ToggleSwitch x:Name="EnableSelectedToggle" Grid.Column="1" Header="Enabled" Toggled="EnableSelectedToggle_Toggled" />
                    </Grid>
                    <AutoSuggestBox x:Name="SearchBox" Grid.Row="1" PlaceholderText="Search words, meanings, pronunciation, or part of speech" TextChanged="SearchBox_TextChanged" QueryIcon="Find" />
                    <ListView x:Name="WordsView" Grid.Row="2" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="WordsView_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" Padding="10" Background="{StaticResource PremiumLayerBrush}" CornerRadius="6">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Term}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding Pronunciation}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Padding="8,4" Background="{StaticResource PremiumAccentSoftBrush}" CornerRadius="6" VerticalAlignment="Top">
                                                <TextBlock FontSize="12" Text="{Binding PartOfSpeech}" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ShortMeaning}" TextWrapping="WrapWholeWords" MaxLines="2" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border x:Name="PreviewPane" Grid.Column="2" Padding="16" Style="{StaticResource PremiumPanelStyle}">
                <StackPanel Spacing="13">
                    <TextBlock Text="Word preview" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="PreviewTermText" FontSize="32" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="PreviewMetaText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="PreviewMeaningText" TextWrapping="WrapWholeWords" />
                    <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Padding="8,4" Background="{StaticResource PremiumLayerBrush}" CornerRadius="6">
                            <TextBlock x:Name="PreviewChapterText" FontSize="12" />
                        </Border>
                        <Border Padding="8,4" Background="{StaticResource PremiumAccentSoftBrush}" CornerRadius="6">
                            <TextBlock x:Name="PreviewTagsText" FontSize="12" />
                        </Border>
                    </StackPanel>
                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" Text="Select a row to inspect it before editing or deleting." TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    </Grid>
</Page>
