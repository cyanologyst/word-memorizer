<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    KeyDown="Page_KeyDown"
    IsTabStop="True">

    <Page.Resources>
        <Storyboard x:Name="CardEntranceStoryboard">
            <DoubleAnimation Storyboard.TargetName="FocusCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="FocusCardTransform" Storyboard.TargetProperty="TranslateY" From="10" To="0" Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="RevealStoryboard">
            <DoubleAnimation Storyboard.TargetName="HiddenPromptText" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.10" />
            <DoubleAnimation Storyboard.TargetName="MeaningText" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22" BeginTime="0:0:0.05" />
            <DoubleAnimation Storyboard.TargetName="MeaningTransform" Storyboard.TargetProperty="TranslateY" From="8" To="0" Duration="0:0:0.22" BeginTime="0:0:0.05">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Padding="24,18,24,20" RowSpacing="14" Background="{StaticResource GlassBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource PremiumPageTitleStyle}" Text="Review" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Focus on one word, reveal its meaning, then rate your recall" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                <TextBlock x:Name="ProgressText" HorizontalAlignment="Right" FontSize="16" FontWeight="SemiBold" />
                <ProgressBar x:Name="SessionProgressBar" Height="5" Maximum="20" />
            </StackPanel>
        </Grid>

        <Border x:Name="SessionSetupPanel" Grid.Row="1" MaxWidth="860" Padding="24" HorizontalAlignment="Stretch" VerticalAlignment="Top" Style="{StaticResource PremiumRaisedPanelStyle}">
            <StackPanel Spacing="16">
                <StackPanel Spacing="5">
                    <TextBlock Style="{StaticResource PageSectionTitleStyle}" Text="Build a review session" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Choose the shape of this session before you begin." />
                </StackPanel>
                <Grid ColumnSpacing="22" RowSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="7">
                        <TextBlock Text="Session length" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ToggleButton x:Name="Goal10Button" MinWidth="52" Content="10" Tag="10" Click="SessionGoalPreset_Click" />
                            <ToggleButton x:Name="Goal20Button" MinWidth="52" Content="20" Tag="20" Click="SessionGoalPreset_Click" />
                            <ToggleButton x:Name="Goal30Button" MinWidth="52" Content="30" Tag="30" Click="SessionGoalPreset_Click" />
                            <NumberBox x:Name="SessionGoalBox" Width="112" Minimum="5" Maximum="100" SmallChange="5" Value="20" SpinButtonPlacementMode="Inline" ValueChanged="SessionGoalBox_ValueChanged" />
                        </StackPanel>
                    </StackPanel>
                    <ComboBox x:Name="SessionWordListBox" Grid.Column="1" MinHeight="36" Header="Wordlist" DisplayMemberPath="Title" />
                    <ComboBox x:Name="SessionModeBox" Grid.Row="1" MinHeight="36" Header="Word selection" SelectedIndex="0">
                        <ComboBoxItem Content="Due and new words" />
                        <ComboBoxItem Content="Difficult words only" />
                    </ComboBox>
                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="8">
                        <ToggleSwitch x:Name="TimedSessionToggle" Header="Timed recall" />
                        <ToggleSwitch x:Name="FocusModeToggle" Header="Hide navigation during the session" IsOn="True" />
                    </StackPanel>
                </Grid>
                <Button HorizontalAlignment="Left" MinWidth="180" Style="{StaticResource PrimaryActionButtonStyle}" Click="StartConfiguredSessionButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE768;" />
                        <TextBlock Text="Start session" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Border x:Name="FocusCard" Grid.Row="1" MaxWidth="1020" Padding="28,24" HorizontalAlignment="Stretch" Style="{StaticResource PremiumPanelStyle}" Opacity="0" Visibility="Collapsed">
            <Border.RenderTransform>
                <CompositeTransform x:Name="FocusCardTransform" />
            </Border.RenderTransform>
            <Grid RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="170" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="WordText" FontSize="56" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="MetaText" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <Border Grid.Column="1" Padding="10,5" Background="{StaticResource PremiumAccentSoftBrush}" CornerRadius="8" VerticalAlignment="Top">
                        <TextBlock x:Name="SourceText" FontSize="12" Text="TOEFL" MaxWidth="250" TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>

                <Border Grid.Row="1" Padding="24" Background="{StaticResource PremiumSurfaceStrongBrush}" CornerRadius="8">
                    <Grid>
                        <StackPanel x:Name="HiddenPromptText" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="1">
                            <FontIcon Glyph="&#xE8D7;" FontSize="24" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock HorizontalAlignment="Center" FontSize="18" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Meaning hidden" />
                            <TextBlock HorizontalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Press Space when ready" />
                        </StackPanel>
                        <TextBlock x:Name="MeaningText" MaxWidth="760" FontSize="22" TextWrapping="WrapWholeWords" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Opacity="0">
                            <TextBlock.RenderTransform>
                                <CompositeTransform x:Name="MeaningTransform" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="RevealButton" Style="{StaticResource PrimaryActionButtonStyle}" HorizontalAlignment="Stretch" AutomationProperties.Name="Reveal meaning, Space" Click="RevealButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE890;" />
                            <TextBlock x:Name="RevealButtonText" Text="Reveal" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" HorizontalAlignment="Stretch" AutomationProperties.Name="Listen to pronunciation" Click="SpeakButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE767;" />
                            <TextBlock Text="Listen" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="KnowButton" Grid.Column="2" Style="{StaticResource SuccessActionButtonStyle}" HorizontalAlignment="Stretch" AutomationProperties.Name="Mark known, 1" Click="KnowButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE73E;" />
                            <TextBlock Text="Know" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="LaterButton" Grid.Column="3" Style="{StaticResource WarningActionButtonStyle}" HorizontalAlignment="Stretch" AutomationProperties.Name="Review later, 2" Click="LaterButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE916;" />
                            <TextBlock Text="Later" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SkipButton" Grid.Column="4" Style="{StaticResource DangerActionButtonStyle}" HorizontalAlignment="Stretch" AutomationProperties.Name="Skip word, 3" Click="SkipButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE711;" />
                            <TextBlock Text="Skip" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="CompletionPanel" Grid.Row="1" MaxWidth="720" Padding="34" HorizontalAlignment="Stretch" Style="{StaticResource PremiumPanelStyle}" Visibility="Collapsed">
            <StackPanel Spacing="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE930;" FontSize="40" Foreground="{StaticResource PremiumSuccessBrush}" />
                <TextBlock HorizontalAlignment="Center" Text="Session complete" FontSize="30" FontWeight="SemiBold" />
                <TextBlock x:Name="SessionSummaryText" HorizontalAlignment="Center" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                <TextBlock x:Name="SessionBreakdownText" HorizontalAlignment="Center" TextAlignment="Center" FontSize="16" />
                <Button Style="{StaticResource PrimaryActionButtonStyle}" MinWidth="180" Content="Start another session" Click="RestartSessionButton_Click" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
            <TextBlock HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" Text="Space reveal   1 know   2 later   3 skip" />
        </Grid>
    </Grid>
</Page>
