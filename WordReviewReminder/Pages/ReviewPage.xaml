<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    KeyDown="Page_KeyDown"
    IsTabStop="True">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Review Mode" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Reveal, decide, and move through a focused session" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock x:Name="ProgressText" HorizontalAlignment="Right" FontSize="18" FontWeight="SemiBold" />
                <ProgressBar x:Name="SessionProgressBar" Height="7" Maximum="20" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <Border Padding="34" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Focus card" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="WordText" FontSize="68" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="MetaText" FontSize="18" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <Border Grid.Row="1" Margin="0,26,0,0" Padding="20" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="10">
                        <StackPanel Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="HiddenPromptText" HorizontalAlignment="Center" FontSize="20" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Meaning hidden" />
                            <TextBlock x:Name="MeaningText" FontSize="22" TextWrapping="WrapWholeWords" Visibility="Collapsed" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <Button x:Name="RevealButton" Content="Reveal Meaning" MinWidth="160" Click="RevealButton_Click" />
                        <Button Content="Listen" MinWidth="110" Click="SpeakButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10">
                <StackPanel Spacing="14">
                    <TextBlock Text="Actions" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Button x:Name="KnowButton" HorizontalAlignment="Stretch" Click="KnowButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" />
                            <TextBlock Text="Know" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="LaterButton" HorizontalAlignment="Stretch" Click="LaterButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE916;" />
                            <TextBlock Text="Later" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SkipButton" HorizontalAlignment="Stretch" Click="SkipButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE711;" />
                            <TextBlock Text="Skip" />
                        </StackPanel>
                    </Button>
                    <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Space reveal" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="1 Know" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="2 Later" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="3 Skip" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    </Grid>
</Page>
