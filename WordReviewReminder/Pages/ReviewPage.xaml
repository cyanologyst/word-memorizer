<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    KeyDown="Page_KeyDown"
    IsTabStop="True">

    <Page.Resources>
        <Storyboard x:Name="CardEntranceStoryboard">
            <DoubleAnimation Storyboard.TargetName="FocusCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.28" />
            <DoubleAnimation Storyboard.TargetName="FocusCardTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="18"
                             To="0"
                             Duration="0:0:0.32">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="RevealStoryboard">
            <DoubleAnimation Storyboard.TargetName="HiddenPromptText"
                             Storyboard.TargetProperty="Opacity"
                             To="0"
                             Duration="0:0:0.14" />
            <DoubleAnimation Storyboard.TargetName="MeaningText"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.32"
                             BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="MeaningTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="14"
                             To="0"
                             Duration="0:0:0.32"
                             BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Padding="28" RowSpacing="18" Background="{StaticResource PremiumPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Review Mode" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Reveal, decide, and move through a focused session" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="7">
                <TextBlock x:Name="ProgressText" HorizontalAlignment="Right" FontSize="18" FontWeight="SemiBold" />
                <ProgressBar x:Name="SessionProgressBar" Height="8" Maximum="20" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <Border x:Name="FocusCard" Padding="36" Style="{StaticResource PremiumPanelStyle}" Opacity="0">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="FocusCardTransform" />
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Focus card" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="WordText" FontSize="70" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                            <TextBlock x:Name="MetaText" FontSize="18" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Border Grid.Column="1" Padding="12,7" Background="{StaticResource PremiumAccentSoftBrush}" CornerRadius="16" VerticalAlignment="Top">
                            <TextBlock x:Name="SourceText" FontSize="12" Text="TOEFL" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,24,0,18" Padding="28" Background="{StaticResource PremiumSurfaceStrongBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="16">
                        <Grid>
                            <StackPanel x:Name="HiddenPromptText" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="1">
                                <FontIcon Glyph="&#xE8D7;" FontSize="28" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock HorizontalAlignment="Center" FontSize="20" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Meaning hidden" />
                                <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Press Space or reveal when ready" />
                            </StackPanel>
                            <TextBlock x:Name="MeaningText" FontSize="24" TextWrapping="WrapWholeWords" VerticalAlignment="Center" Opacity="0">
                                <TextBlock.RenderTransform>
                                    <CompositeTransform x:Name="MeaningTransform" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <Button x:Name="RevealButton" Style="{StaticResource PrimaryActionButtonStyle}" MinWidth="170" Click="RevealButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE890;" />
                                <TextBlock x:Name="RevealButtonText" Text="Reveal Meaning" />
                            </StackPanel>
                        </Button>
                        <Button MinWidth="120" Click="SpeakButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE767;" />
                                <TextBlock Text="Listen" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="18" Style="{StaticResource PremiumPanelStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Confidence" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Button x:Name="KnowButton" Style="{StaticResource SuccessActionButtonStyle}" HorizontalAlignment="Stretch" Click="KnowButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" />
                            <TextBlock Text="Know" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="LaterButton" Style="{StaticResource WarningActionButtonStyle}" HorizontalAlignment="Stretch" Click="LaterButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE916;" />
                            <TextBlock Text="Later" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SkipButton" Style="{StaticResource DangerActionButtonStyle}" HorizontalAlignment="Stretch" Click="SkipButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE711;" />
                            <TextBlock Text="Skip" />
                        </StackPanel>
                    </Button>
                    <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Shortcuts" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Space - reveal" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="1 - know" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="2 - later" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="3 - skip" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="CompletionPanel" Grid.ColumnSpan="2" Padding="34" Style="{StaticResource PremiumPanelStyle}" Visibility="Collapsed">
                <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520">
                    <FontIcon Glyph="&#xE930;" FontSize="44" Foreground="{StaticResource PremiumSuccessBrush}" />
                    <TextBlock HorizontalAlignment="Center" Text="Session complete" FontSize="34" FontWeight="SemiBold" />
                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Nice rhythm. You hit the review target for this session." TextWrapping="WrapWholeWords" />
                    <Button Style="{StaticResource PrimaryActionButtonStyle}" MinWidth="180" Content="Start another session" Click="RestartSessionButton_Click" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    </Grid>
</Page>
