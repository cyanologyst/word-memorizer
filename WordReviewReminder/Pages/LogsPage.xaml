<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged">

    <Grid Padding="{StaticResource CompactPagePadding}" RowSpacing="12" Background="{StaticResource PremiumPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="HeaderGrid" ColumnSpacing="16" RowSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="HeaderActionColumn" Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource PremiumPageTitleStyle}" Text="Logs" />
                <TextBlock Style="{StaticResource PremiumPageSubtitleStyle}" Text="Search, inspect, and export your review history" />
            </StackPanel>
            <CommandBar x:Name="PageCommandBar" Grid.Column="1" Background="Transparent" DefaultLabelPosition="Right">
                <AppBarButton x:Name="ExportButton" Icon="Save" Label="Export results" AutomationProperties.Name="Export filtered logs as JSON Lines" Click="ExportButton_Click" />
                <AppBarButton Icon="Refresh" Label="Refresh" AutomationProperties.Name="Refresh review history" Click="RefreshButton_Click" />
            </CommandBar>
        </Grid>

        <Border Grid.Row="1" Padding="12" Style="{StaticResource PremiumPanelStyle}">
            <Grid x:Name="FilterGrid" ColumnSpacing="10" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="ActionFilterColumn" Width="140" />
                    <ColumnDefinition x:Name="ListFilterColumn" Width="190" />
                    <ColumnDefinition x:Name="SortColumn" Width="150" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="CompactFilterRow" Height="0" />
                    <RowDefinition x:Name="DateFilterRow" Height="0" />
                </Grid.RowDefinitions>
                <AutoSuggestBox x:Name="SearchBox" Header="Search" PlaceholderText="Word, word ID, or wordlist" QueryIcon="Find" TextChanged="SearchBox_TextChanged" AutomationProperties.Name="Search review history" />
                <ComboBox x:Name="ActionFilterBox" Grid.Column="1" Header="Result" SelectedIndex="0" SelectionChanged="Filter_Changed" AutomationProperties.Name="Filter by result">
                    <x:String>All results</x:String>
                    <x:String>Known</x:String>
                    <x:String>Review Later</x:String>
                    <x:String>Skipped</x:String>
                </ComboBox>
                <ComboBox x:Name="WordListFilterBox" Grid.Column="2" Header="Wordlist" DisplayMemberPath="Title" SelectionChanged="Filter_Changed" AutomationProperties.Name="Filter by wordlist" />
                <ComboBox x:Name="SortBox" Grid.Column="3" Header="Sort" SelectedIndex="0" SelectionChanged="Filter_Changed" AutomationProperties.Name="Sort review history">
                    <x:String>Newest first</x:String>
                    <x:String>Oldest first</x:String>
                    <x:String>Word A-Z</x:String>
                </ComboBox>
                <StackPanel x:Name="DateFilterPanel" Grid.Row="2" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="10">
                    <CalendarDatePicker x:Name="FromDatePicker" Width="180" Header="From" PlaceholderText="Any date" DateChanged="DateFilter_Changed" AutomationProperties.Name="Review history start date" />
                    <CalendarDatePicker x:Name="ToDatePicker" Width="180" Header="To" PlaceholderText="Any date" DateChanged="DateFilter_Changed" AutomationProperties.Name="Review history end date" />
                    <Button VerticalAlignment="Bottom" Style="{StaticResource CompactIconButtonStyle}" ToolTipService.ToolTip="Clear dates" AutomationProperties.Name="Clear date range" Click="ClearDatesButton_Click">
                        <FontIcon Glyph="&#xE894;" FontSize="15" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PremiumPanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Padding="18,0" ColumnSpacing="14" Background="{StaticResource PremiumSurfaceStrongBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="128" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="112" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource PremiumCaptionTextStyle}" Text="TIME" />
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource PremiumCaptionTextStyle}" Text="WORD / WORDLIST" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource PremiumCaptionTextStyle}" Text="RESULT" />
                </Grid>
                <ListView
                    x:Name="LogsView"
                    Grid.Row="1"
                    Padding="6,2"
                    HorizontalContentAlignment="Stretch"
                    IsItemClickEnabled="True"
                    ItemClick="LogsView_ItemClick"
                    DoubleTapped="LogsView_DoubleTapped"
                    ScrollViewer.VerticalScrollBarVisibility="Visible">
                    <ListView.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Open word details" Icon="OpenFile" Click="OpenDetailsMenuItem_Click" />
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="12,10,12,4" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Key}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="MinHeight" Value="54" />
                            <Setter Property="Padding" Value="12,3" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="48" ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="116" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="112" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Time}" />
                                    <TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="{Binding ResponseTime}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Term}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource PremiumCaptionTextStyle}" Text="{Binding WordListTitle}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                    <FontIcon Glyph="{Binding ActionGlyph}" FontSize="14" Foreground="{Binding ActionBrush}" />
                                    <TextBlock VerticalAlignment="Center" Text="{Binding ActionLabel}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Border x:Name="EmptyLogsPanel" Grid.Row="1" Margin="16" Style="{StaticResource EmptyStatePanelStyle}" Visibility="Collapsed">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE823;" FontSize="24" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="EmptyLogsTitle" Style="{StaticResource EmptyStateTitleStyle}" Text="No review history yet" />
                        <TextBlock x:Name="EmptyLogsMessage" MaxWidth="420" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Complete a review and the result will appear here." TextAlignment="Center" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <ProgressRing x:Name="LogsProgress" Grid.Row="1" Width="32" Height="32" IsActive="False" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" AutomationProperties.LiveSetting="Polite" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Button x:Name="PreviousPageButton" Style="{StaticResource CompactIconButtonStyle}" ToolTipService.ToolTip="Previous page" AutomationProperties.Name="Previous history page" Click="PreviousPageButton_Click">
                    <FontIcon Glyph="&#xE76B;" />
                </Button>
                <TextBlock x:Name="PageText" MinWidth="92" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
                <Button x:Name="NextPageButton" Style="{StaticResource CompactIconButtonStyle}" ToolTipService.ToolTip="Next page" AutomationProperties.Name="Next history page" Click="NextPageButton_Click">
                    <FontIcon Glyph="&#xE76C;" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
