<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordReviewReminder.Pages.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="28,20,28,28" RowSpacing="16" Background="{StaticResource PremiumPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Logs" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Recent review activity, streak moments, and JSONL export" />
            </StackPanel>
            <ComboBox x:Name="FilterBox" Grid.Column="1" MinWidth="160" SelectionChanged="FilterBox_SelectionChanged">
                <ComboBoxItem Content="All events" />
                <ComboBoxItem Content="Known" />
                <ComboBoxItem Content="Later" />
                <ComboBoxItem Content="Skipped" />
            </ComboBox>
        </Grid>

        <Border Grid.Row="1" Padding="16" Style="{StaticResource PremiumPanelStyle}">
            <ListView x:Name="LogsView">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3,0,3" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <Rectangle Width="2" Fill="{ThemeResource CardStrokeColorDefaultBrush}" HorizontalAlignment="Center" />
                                <Ellipse Width="12" Height="12" Fill="{StaticResource PremiumAccentBrush}" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Time}" />
                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{Binding Date}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="3">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Term}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding WordListId}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Border Grid.Column="3" Padding="10,5" Background="{StaticResource PremiumLayerBrush}" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Action}" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Content="Export logs" Click="ExportButton_Click" />
            <Button Grid.Column="1" Content="Refresh" Click="RefreshButton_Click" />
            <TextBlock x:Name="StatusText" Grid.Column="2" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
    </Grid>
</Page>
